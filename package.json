{
  "name": "yvon.dev",
  "version": "2.0.0",
  "license": "MIT",
  "scripts": {
    "start": "PORT=3435 next dev --webpack",
    "dev": "PORT=3434 cross-env INIT_CWD=$PWD next dev --webpack",
    "build": "cross-env INIT_CWD=$PWD next build --webpack && npm run postbuild",
    "postbuild": "cross-env NODE_OPTIONS='--experimental-json-modules' tsx ./scripts/post-build.ts",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "eslint app components layouts utils scripts --fix",
    "prepare": "husky",
    "db:init": "npx drizzle-kit generate && npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio --port 8088",
    "seed": "tsx ./scripts/seed.ts",
    "typecheck": "npx tsc -b"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@giscus/react": "^3.1.0",
    "@headlessui/react": "2.2.10",
    "@next/bundle-analyzer": "16.2.10",
    "@octokit/graphql": "^9.0.3",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/better-sqlite3": "^7.6.13",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.5.2",
    "better-sqlite3": "^12.11.1",
    "body-scroll-lock": "^4.0.0-beta.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contentlayer2": "0.5.8",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "esbuild": "0.28.1",
    "eslint-config-next": "^16.2.10",
    "framer-motion": "^12.42.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "image-size": "2.0.2",
    "js-yaml": "^5.2.1",
    "kbar": "0.1.0-beta.48",
    "lucide-react": "^1.23.0",
    "mdast-util-to-string": "^4.0.0",
    "next": "16.2.10",
    "next-contentlayer2": "0.5.8",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.16",
    "postgres": "^3.4.9",
    "probe-image-size": "^7.3.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-medium-image-zoom": "^5.4.8",
    "react-share": "^5.3.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.2",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "shiki": "^4.3.1",
    "swr": "^2.4.2",
    "tailwindcss": "^4.3.2",
    "typed.js": "^3.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@svgr/webpack": "^8.1.0",
    "@types/body-scroll-lock": "^3.1.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.0",
    "@types/probe-image-size": "^7.2.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "cross-env": "^10.1.0",
    "csv-parser": "^3.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "fontmin": "^1.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rss-parser": "^3.13.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "overrides": {
    "kbar": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
